------------------------------------------------
-- 📱 UI
------------------------------------------------
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "InvisibleJoystickUI"
screenGui.Parent = player:WaitForChild("PlayerGui")

local joystickZone = Instance.new("Frame")
joystickZone.Size = UDim2.new(0.3, 0, 0.5, 0)
