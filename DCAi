-- 🔥 跨服务器数据（关键）
------------------------------------------------
local teleportData = TeleportService:GetLocalPlayerTeleportData() or {}

local serverHopCount = (teleportData.serverHopCount or 0)
local startTime = (teleportData.startTime or tick())

------------------------------------------------
