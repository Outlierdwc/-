------------------------------------------------
-- 🎮 移动参数
------------------------------------------------
local autoForwardSpeed = 16
local strafeSpeed = 10
local currentStrafe = 0
local isMoving = false
local touchStartPos = nil

------------------------------------------------
-- 📊 UI卡片（带统计）
------------------------------------------------
