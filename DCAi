local statsLabel = createUI()

------------------------------------------------
-- ⏱️ 实时统计（运行时间 + 换服次数）
------------------------------------------------
RunService.Heartbeat:Connect(function()
    local t = math.floor(tick() - startTime)

    local h = math.floor(t / 3600)
    local m = math.floor((t % 3600) / 60)
    local s = t % 60

    statsLabel.Text =
        "换服次数: " .. serverHopCount ..
        " | 运行时间: " .. string.format("%02d:%02d:%02d", h, m, s)
end)

------------------------------------------------
-- 🎮 触控移动
------------------------------------------------
local function onInputBegan(input, gp)
    if gp then return end
    if input.UserInputType == Enum.UserInputType.Touch then

        local pos = Vector2.new(input.Position.X, input.Position.Y)
        local zonePos = joystickZone.AbsolutePosition
        local zoneSize = joystickZone.AbsoluteSize

        if pos.X >= zonePos.X and pos.X <= zonePos.X + zoneSize.X and
           pos.Y >= zonePos.Y and pos.Y <= zonePos.Y + zoneSize.Y then

            isMoving = true
            touchStartPos = pos
        end
    end
end

local function onInputChanged(input)
    if not isMoving then return end
    if input.UserInputType ~= Enum.UserInputType.Touch then return end

    local currentPos = Vector2.new(input.Position.X, input.Position.Y)
    local deltaX = currentPos.X - (touchStartPos.X)

    local maxDelta = joystickZone.AbsoluteSize.X / 2
    currentStrafe = math.clamp(deltaX / maxDelta, -1, 1)
end

local function onInputEnded(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        isMoving = false
        currentStrafe = 0
    end
end

UserInputService.InputBegan:Connect(onInputBegan)
UserInputService.InputChanged:Connect(onInputChanged)
UserInputService.InputEnded:Connect(onInputEnded)

------------------------------------------------
-- 🚶自动移动
------------------------------------------------
RunService.Heartbeat:Connect(function()
    if not humanoid or not character then return end

    local cam = workspace.CurrentCamera
    if not cam then return end

    local cf = cam.CFrame
    local forward = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z).Unit
    local right = Vector3.new(cf.RightVector.X, 0, cf.RightVector.Z).Unit

    local move = forward * autoForwardSpeed + right * currentStrafe * strafeSpeed
    humanoid:Move(move, true)
end)

------------------------------------------------
-- 💰 自动收集逻辑
------------------------------------------------
task.spawn(function()
    while true do
        task.wait(1)

        local lp = Players.LocalPlayer
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        for _, v in pairs(workspace.Game.Entities.ItemPickup:GetChildren()) do
            local pp = v.PrimaryPart
            if pp then
                local prompt = pp:FindFirstChildOfClass("ProximityPrompt")
                if prompt and prompt.ObjectText == "Money Printer" then
                    hrp.CFrame = pp.CFrame
                    task.wait(0.5)
                    fireproximityprompt(prompt)
                end
            end
        end
    end
end)

------------------------------------------------
-- 🔁 自动换服务器（带统计）
------------------------------------------------
task.delay(2, function()

    local placeId = game.PlaceId
    local api = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"

    local function getServers(cursor)
        local url = api .. (cursor and "&cursor=" .. cursor or "")
        local raw = game:HttpGet(url)
        return HttpService:JSONDecode(raw)
    end

    local server
    local cursor

    repeat
        local data = getServers(cursor)

        if data and data.data and #data.data > 0 then
            server = data.data[math.random(1, #data.data)]
        end

        cursor = data.nextPageCursor
    until server

    local options = Instance.new("TeleportOptions")
    options:SetTeleportData({
        serverHopCount = serverHopCount + 1,
        startTime = startTime
    })

    TeleportService:TeleportToPlaceInstance(
        placeId,
        server.id,
        player,
        options
    )
end)
