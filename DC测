local autoForwardSpeed = 16
local strafeSpeed = 10
local currentStrafe = 0
local isMoving = false
local touchStartPos = nil
local function onInputBegan(input, gameProcessed)
    if gameProcessed then return end
    
    if input.UserInputType == Enum.UserInputType.Touch then
        local inputPos = Vector2.new(input.Position.X, input.Position.Y)
        local zonePos = joystickZone.AbsolutePosition
        local zoneSize = joystickZone.AbsoluteSize
        if inputPos.X >= zonePos.X and inputPos.X <= zonePos.X + zoneSize.X and
           inputPos.Y >= zonePos.Y and inputPos.Y <= zonePos.Y + zoneSize.Y then
            isMoving = true
            touchStartPos = inputPos
        end
    end
end
local function onInputChanged(input, gameProcessed)
    if not isMoving or input.UserInputType ~= Enum.UserInputType.Touch then return end
    local currentPos = Vector2.new(input.Position.X, input.Position.Y)
    if touchStartPos then
        local deltaX = currentPos.X - touchStartPos.X
        local maxDelta = joystickZone.AbsoluteSize.X / 2
        currentStrafe = math.clamp(deltaX / maxDelta, -1, 1)
    end
end
local function onInputEnded(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Touch then
        isMoving = false
        currentStrafe = 0
        touchStartPos = nil
    end
end
UserInputService.InputBegan:Connect(onInputBegan)
